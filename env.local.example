# ─── Agora ────────────────────────────────────────────────────────────────────
# Required: found in Agora Console → your project → "App ID"
NEXT_PUBLIC_AGORA_APP_ID=

# Required: found in Agora Console → your project → "App Certificate"
# Server-side only. Never expose this in client code.
NEXT_AGORA_APP_CERTIFICATE=

# Optional: set to 1 / true / yes to log the full Agora start-agent JSON from the server SDK
# (includes `mllm.api_key`). Dev-only; never enable where logs are retained or shared.
# NEXT_AGORA_LOG_JOIN_REQUEST=1

# UID the AI agent joins the channel with.
# - Must match the agentUid set in app/api/invite-agent/route.ts.
# - (Optional override) Defaults: to 123456 (via lib/agora.ts)
NEXT_PUBLIC_AGENT_UID=123456

# ─── xAI Realtime MLLM ────────────────────────────────────────────────────────
# Required: xAI Realtime API key. The invite-agent route runs in MLLM-only mode
# and uses the custom XAI vendor in lib/vendors/xai-mllm.ts to drive ASR + LLM + TTS
# end-to-end through xAI's Realtime endpoint.
NEXT_XAI_API_KEY=

# Optional: override the xAI Realtime WebSocket endpoint.
# Defaults to wss://api.x.ai/v1/realtime.
# NEXT_XAI_URL=wss://api.x.ai/v1/realtime

# Optional: xAI Realtime voice id. Defaults to "eve".
# NEXT_XAI_VOICE=eve

# Optional: xAI realtime / voice backend model id. Defaults to grok-4-1-non-reasoning (lib/vendors/xai-mllm.ts).
# NEXT_XAI_MODEL=grok-4-1-non-reasoning

# Optional: server VAD (Python ServerVad defaults: threshold 0.5, prefix_padding_ms 300, silence_duration_ms 200).
# NEXT_XAI_VAD_THRESHOLD=0.5
# NEXT_XAI_VAD_PREFIX_PADDING_MS=300
# NEXT_XAI_VAD_SILENCE_DURATION_MS=200

# ─── Agent behavior ───────────────────────────────────────────────────────────
# Optional opening line override
# NEXT_AGENT_GREETING=Hi there! I'm Ada, your virtual assistant from Agora. How can I help?
