# ─── Agora ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_AGORA_APP_ID=
NEXT_AGORA_APP_CERTIFICATE=
NEXT_AGORA_CUSTOMER_ID=
NEXT_AGORA_CUSTOMER_SECRET=
NEXT_AGORA_CONVO_AI_BASE_URL=https://api.agora.io/api/conversational-ai-agent/v2/projects/
NEXT_AGENT_UID=

# ─── STT / ASR ────────────────────────────────────────────────────────────────
# Vendor options: ares (no key needed), deepgram, microsoft, soniox
NEXT_ASR_VENDOR=deepgram

# Deepgram — https://console.deepgram.com (required if NEXT_ASR_VENDOR=deepgram)
NEXT_DEEPGRAM_API_KEY=
NEXT_DEEPGRAM_MODEL=nova-3
NEXT_DEEPGRAM_LANGUAGE=en

# Microsoft Azure STT (required if NEXT_ASR_VENDOR=microsoft)
NEXT_MICROSOFT_STT_KEY=
NEXT_MICROSOFT_STT_REGION=eastus

# Soniox (required if NEXT_ASR_VENDOR=soniox)
NEXT_SONIOX_API_KEY=

# ─── LLM ──────────────────────────────────────────────────────────────────────
NEXT_LLM_URL=https://api.openai.com/v1/chat/completions
NEXT_LLM_MODEL=gpt-4o
NEXT_LLM_API_KEY=

# Custom LLM mode — routes the agent through /api/chat/completions (Vercel AI SDK).
# Agora calls this URL from its servers, so it must be publicly reachable.
#
# Local dev:   ngrok http 3000  →  NEXT_CUSTOM_LLM_URL=https://<id>.ngrok-free.app
# Production:  NEXT_CUSTOM_LLM_URL=https://your-app.vercel.app
#
# The /api/chat/completions path is appended automatically if omitted.
NEXT_CUSTOM_LLM_URL=

# Shared secret that authenticates Agora's requests to /api/chat/completions.
# Agora forwards this value as a Bearer token so the proxy can reject
# unauthorised callers. Use any strong random string (e.g. openssl rand -hex 32).
# Optional in local dev; strongly recommended in production.
NEXT_CUSTOM_LLM_SECRET=

# ─── TTS ──────────────────────────────────────────────────────────────────────
# Vendor options: elevenlabs, microsoft
NEXT_TTS_VENDOR=elevenlabs

# ElevenLabs — https://elevenlabs.io (required if NEXT_TTS_VENDOR=elevenlabs)
NEXT_ELEVENLABS_API_KEY=
NEXT_ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
NEXT_ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# Microsoft Azure TTS (required if NEXT_TTS_VENDOR=microsoft)
NEXT_MICROSOFT_TTS_KEY=
NEXT_MICROSOFT_TTS_REGION=eastus
NEXT_MICROSOFT_TTS_VOICE_NAME=en-US-AndrewMultilingualNeural
NEXT_MICROSOFT_TTS_RATE=1.1
NEXT_MICROSOFT_TTS_VOLUME=70
